            // SmallSwitch { }
            //
            // InfoArea {
            //     title: "Cold temperature";
            //     text_color: Palette.blue;
            // }

            MyVerticalLayout {

                Baking { }

                // HorizontalLayout {
                //     alignment: end;
                //     PictogramButton {
                //         enabled: true;
                //         clicked => {
                //             Logic.close_program();
                //         }
                //     }
                // }
            }
        }

        H3Text {
            x: Const.border_spacing;
            text: "Log messages:";
            horizontal-alignment: left;
        }

        Rectangle {
            x: Const.border_spacing;
            width: Const.useable_width - 2 * Const.border_spacing;
            height: 250px;

            ListView {

                property <int> cnt: 0;

                for data[idx] in Logic.log_messages: Rectangle {
                    height: 25px;
                    background: mod(idx, 2) == 0 ? Palette.mantle : Palette.crust;

                    Text {
                        x: 0;
                        font-size: 12pt;
                        color: Palette.text;
                        text: data;
                        horizontal-alignment: left;
                    }
                }
            }
        }
    }
}
